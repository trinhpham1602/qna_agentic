      "name": "date",
      "values": [
        {
          "value": "2026-05-01",
          "synonyms": [
            "mai",
            "ngày mai"
          ]
        },
        {
          "value": "2026-05-02",
          "synonyms": [
            "mốt",
            "ngày kia"
          ]
        }
      ]
    },
    {
