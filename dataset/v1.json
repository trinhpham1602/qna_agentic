        {
          "value": "morning",
          "synonyms": [
            "sáng"
          ]
        },
        {
          "value": "afternoon",
          "synonyms": [
            "chiều"
          ]
        },
        {
          "value": "evening",
          "synonyms": [
            "tối"
          ]
        }
      ]
    },
