    "origin": "location",
    "destination": "location",
    "departure_date": "date",
    "return_date": "date",
    "passengers": "passenger_count",
    "cabin_class": "cabin_class",
    "airline": "airline",
    "price": "price_range",
    "time": "time_range",
    "booking_code": "booking_code",
    "payment_method": "payment_method"
  },
  "context_rules": [
    {
      "intent": "search_flight",
      "required_slots": [
        "origin",
        "destination",
        "departure_date"
      ]
    },
    {
      "intent": "select_flight",
      "required_slots": [
        "selected_flight"
      ]
    },
    {
      "intent": "create_booking",
      "required_slots": [
        "selected_flight",
        "passengers"
      ]
    },
    {
      "intent": "confirm_payment",
      "required_slots": [
        "booking_id",
        "payment_method"
      ]
    }
  ]
